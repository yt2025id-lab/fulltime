# FullTime Relay Service — Environment Variables
# Copy to .env and fill in your values

# Solana RPC URL (devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Relay authority keypair (base58 private key)
RELAY_AUTHORITY_PRIVATE_KEY=

# TxLINE API configuration
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J

# FullTime program ID (will be filled after deploy)
FULLTIME_PROGRAM_ID=58a2h7zogfV5ZgUsfyr1DZ36j1bgcwfCkGvd8fwppy5x

# Polling interval in milliseconds (default: 2 menit)
POLL_INTERVAL_MS=120000
